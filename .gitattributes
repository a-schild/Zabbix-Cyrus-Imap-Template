# Force LF line endings in the repo and on checkout for all platforms, so the
# shell script and configs always work on the (Linux) Cyrus host regardless of
# the contributor's core.autocrlf setting.
* text=auto eol=lf

*.sh   text eol=lf
*.conf text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
LICENSE text eol=lf
